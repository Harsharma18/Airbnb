    <p>Tropical</p>
  </div>
  
  <div class="filter">
    <i class="fas fa-city"></i>
    <p>Iconic Cities</p>
  </div>
  <button id="nextBtn"><i class="fa-solid fa-circle-chevron-right"></i></button>
  <div class="tax-toggle">
    <div class="form-check form-switch form-check-reverse">
      <input 
      class="form-check-input" 
      type="checkbox" 
      id="flexSwitchCheckReverse">
      <label class="form-check-label" for="flexSwitchCheckReverse">Taxes</label>
    </div>
  </div>
</div>


<script>
  let  currentIndex = 0;
  let filters = document.querySelectorAll('.filter');

  function displayFilter() {
    for (let i = 0; i < filters.length; i++) {
    let filter = filters[i];
    if (i === currentIndex) {
      filter.style.opacity = '1';
    } else {
      filter.style.opacity = '0.6';
    }
  }
  }

  function nextIcon() {
    if (currentIndex < filters.length - 1) {
      currentIndex++;
      displayFilter();
    }
  }

  function previousIcon() {
    if (currentIndex > 0) {
      currentIndex--;
      displayFilter();
    }
  }
  function selectFilter(index) {
    currentIndex = index;
    displayFilter();
  }

  // Assign click event handlers to each filter
  for (let i = 0; i < filters.length; i++) {
    filters[i].mouseover() = function() {
      selectFilter(i);
    };
  }

  document.getElementById('prevBtn').onclick = previousIcon;
  document.getElementById('nextBtn').onclick = nextIcon;

  // Initial display
  displayFilter();
</script>






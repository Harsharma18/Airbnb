<%layout("/layouts/boilerplate") %>
<style>
  #filters{
   display:flex;
   flex-wrap: nowrap;
   align-items: center;
  }
  .filter{
    text-align: center;
    margin-right:2rem;
    margin-top:2rem;
    opacity:0.6;
  }
  .filter:hover{
    opacity: 1;
    cursor: pointer;

  }
  #prevBtn, #nextBtn {
    background-color: transparent;
    border: none; /* No border */
    cursor: pointer;
    outline: none; /* Remove outline */
    display: flex;
    align-items: center;
    justify-content: center;
    color: #555; /* Icon color */
    font-size: 24px; /* Icon size */
  }

  /* Style for the chevron icons */
  .fa-circle-chevron-left, .fa-circle-chevron-right {
    color: #555; /* Icon color */
    font-size: 24px; /* Icon size */
  }
  /* Apply some margin to the left and right buttons */
  #prevBtn {
    margin-right: 0.5rem;
  }

  #nextBtn {
    margin-left: 0.5rem;
  }

  .filter p {
    margin-top: 0.5rem; /* Add some space between icon and text */
  }
  .tax-info{
    display:none;
  }
 .tax-toggle{
  border:1px solid black;
  border-radius:1rem;
  height:1rem;
  padding:1rem;
  margin-left: 1rem;
  display: flex;
  align-items: center;
 }
  
</style>
<div id="filters">
